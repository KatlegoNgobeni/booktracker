# BookTracker environment variables
# Copy this file to .env and fill in the values for local development.
# .env is gitignored — never commit real secrets.

# PostgreSQL (used by docker-compose and the Spring Boot datasource)
POSTGRES_DB=booktracker
POSTGRES_USER=booktracker
POSTGRES_PASSWORD=

# Spring Boot datasource (reads from these env vars in application.properties)
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/booktracker
SPRING_DATASOURCE_USERNAME=booktracker
SPRING_DATASOURCE_PASSWORD=

# JWT secret — base64-encoded value that decodes to at least 32 bytes (D-07).
# Generate with: openssl rand -base64 32
# The resulting string is already base64-encoded and decodes to 32 bytes.
# Never commit the real value; this placeholder is intentionally blank.
JWT_SECRET=
